# LLM Configuration
DEFAULT_MODEL=gpt-4o-mini
FALLBACK_MODEL=gpt-3.5-turbo
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0
USE_FAKEREDIS=true

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_USE_LOCAL=true

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# API Server
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=1
CORS_ORIGINS=["*"]
RATE_LIMIT=30/minute

# Research
DEFAULT_DEPTH=standard
MAX_REVISION_CYCLES=2
CRITIQUE_THRESHOLD=0.7
